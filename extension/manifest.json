{
  "manifest_version": 3,
  "name": "WebMCP Bridge",
  "version": "0.3.0",
  "description": "Expose WebMCP tools on window.__webmcp_tools__ for AI agents",
  "permissions": [],
  "host_permissions": ["<all_urls>"],
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["dist/content-main.global.js"],
      "run_at": "document_start",
      "world": "MAIN"
    }
  ],
  "minimum_chrome_version": "116"
}
